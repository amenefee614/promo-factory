# === Required for Railway Deploy ===

# Database — Railway auto-fills this when you add a MySQL plugin
DATABASE_URL=mysql://user:password@host:3306/railway

# OpenRouter LLM — Get your key at https://openrouter.ai/keys
BUILT_IN_FORGE_API_URL=https://openrouter.ai/api
BUILT_IN_FORGE_API_KEY=sk-or-v1-your-key-here

# Model to use via OpenRouter (see https://openrouter.ai/models)
LLM_MODEL=google/gemini-2.5-flash

# JWT secret for session cookies — use any random string
JWT_SECRET=change-me-to-a-random-string

# Server port — Railway sets PORT automatically, don't change
PORT=3000
